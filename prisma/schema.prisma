generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USER
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Better Auth fields
  name          String?
  emailVerified Boolean   @default(false)
  image         String?

  // Business flag
  isBusiness Boolean @default(false)

  // Admin flag
  isAdmin Boolean @default(false)

  // Stripe
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?
  subscriptionStatus   SubscriptionStatus   @default(FREE)

  // Relations
  profile           Profile?
  sessions          Session[]
  accounts          Account[]
  createdServices   Service[]
  bookingsAsRequester Booking[] @relation("BookingRequester")
  bookingsAsProvider  Booking[] @relation("BookingProvider")
  reviewsWritten    Review[]  @relation("ReviewAuthor")
  reviewsReceived   Review[]  @relation("ReviewTarget")
  reputation        UserReputation?
  bookingComments   BookingComment[]
  notifications     Notification[]

  // Business relations
  ownedBusiness     Business?
  employeeAt        Employee?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================
// BUSINESS
// ============================================

model Business {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  coverUrl    String?

  // Main Category (for search/filtering)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Contact
  phone   String?
  email   String?
  website String?

  // Address
  address    String?
  city       String?
  postalCode String?
  country    String   @default("FR")
  latitude   Float?
  longitude  Float?

  // Subscription
  subscriptionTier   BusinessTier   @default(STARTER)
  subscriptionStatus SubscriptionStatus @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Settings
  isVerified    Boolean @default(false)
  isActive      Boolean @default(true)
  acceptsOnlineBooking Boolean @default(true)
  isEarlyAdopter Boolean @default(false)

  // Vacation mode
  isOnVacation    Boolean @default(false)
  vacationMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner      User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  employees  Employee[]
  services   BusinessService[]
  hours      BusinessHours[]
  categories BusinessCategory[]
  images     BusinessImage[]

  @@index([city])
  @@index([categoryId])
}

model BusinessImage {
  id         String @id @default(cuid())
  businessId String
  url        String
  sortOrder  Int    @default(0)

  createdAt DateTime @default(now())

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Employee {
  id         String  @id @default(cuid())
  businessId String
  userId     String? @unique // Optional: can be linked to a user account

  firstName  String
  lastName   String
  email      String?
  phone      String?
  avatarUrl  String?
  role       String? // e.g. "Coiffeur", "Masseur", etc.
  bio        String?

  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business       Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user           User?                 @relation(fields: [userId], references: [id])
  availabilities EmployeeAvailability[]
  services       EmployeeService[]
  bookings       Booking[]

  @@index([businessId])
}

model EmployeeAvailability {
  id         String @id @default(cuid())
  employeeId String

  dayOfWeek  Int    // 0 = Sunday, 1 = Monday, etc.
  startTime  String // "09:00"
  endTime    String // "18:00"

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
}

model BusinessHours {
  id         String @id @default(cuid())
  businessId String

  dayOfWeek  Int     // 0 = Sunday, 1 = Monday, etc.
  startTime  String  // "09:00"
  endTime    String  // "18:00"
  isClosed   Boolean @default(false)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

model BusinessCategory {
  id         String @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services BusinessService[]

  @@unique([businessId, name])
  @@index([businessId])
}

model BusinessService {
  id          String @id @default(cuid())
  businessId  String

  name        String
  description String?
  detailedDescription String? // Rich text HTML content for detailed service info

  // Pricing
  priceCents  Int
  currency    String @default("EUR")

  // Duration in minutes
  durationMinutes Int

  // Global Category (deprecated for business services)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Business-specific Category
  businessCategoryId String?
  businessCategory   BusinessCategory? @relation(fields: [businessCategoryId], references: [id])

  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business  Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employees EmployeeService[]
  bookings  Booking[]

  @@index([businessId])
  @@index([categoryId])
  @@index([businessCategoryId])
}

model EmployeeService {
  employeeId        String
  businessServiceId String

  // Relations
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  businessService BusinessService @relation(fields: [businessServiceId], references: [id], onDelete: Cascade)

  @@id([employeeId, businessServiceId])
}

// ============================================
// PROFILE
// ============================================

model Profile {
  userId      String  @id
  displayName String?
  avatarUrl   String?
  coverUrl    String?
  bio         String?
  city        String?
  address     String?
  latitude    Float?
  longitude   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  images PeopleImage[]
}

model PeopleImage {
  id        String @id @default(cuid())
  profileId String
  url       String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [userId], onDelete: Cascade)

  @@index([profileId])
}

// ============================================
// SERVICE
// ============================================

model Service {
  id          String        @id @default(cuid())
  kind        ServiceKind
  title       String
  description String

  // Pricing
  priceCents      Int?
  pricingType     String  @default("HOURLY") // "HOURLY" or "FIXED"
  currency        String  @default("EUR")

  // Duration (in minutes)
  durationMinutes Int?

  // Availability
  availableDays     String[] // e.g. ["MONDAY", "TUESDAY", "WEDNESDAY"]
  availableFromTime String?  // e.g. "09:00"
  availableToTime   String?  // e.g. "18:00"
  availableFromDate DateTime?
  availableToDate   DateTime?

  // Location
  city      String?
  latitude  Float?
  longitude Float?

  // Category & Tags
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  tags       ServiceTag[]

  // Owner
  createdByUserId String
  createdBy       User   @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  // Status
  status ServiceStatus @default(DRAFT)

  // Time
  deadlineAt DateTime?
  expiresAt  DateTime

  // Urgency
  urgency Urgency @default(FLEXIBLE)

  // Recurrence
  isRecurring    Boolean     @default(false)
  recurrence     Recurrence  @default(ONE_TIME)
  sessionsCount  Int?

  // Boost
  boostedUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings Booking[]

  @@index([kind])
  @@index([status])
  @@index([categoryId])
  @@index([createdByUserId])
  @@index([expiresAt])
  @@index([boostedUntil])
  @@index([city])
  @@index([latitude, longitude])
}

model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  parentId String?

  parent           Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children         Category[]        @relation("CategoryHierarchy")
  services         Service[]
  businessServices BusinessService[]
  businesses       Business[]
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  services ServiceTag[]
}

model ServiceTag {
  serviceId String
  tagId     String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([serviceId, tagId])
}

// ============================================
// BOOKING
// ============================================

model Booking {
  id        String @id @default(cuid())

  // For P2P bookings (individual services)
  serviceId   String?
  requesterId String
  providerId  String

  // For Business bookings
  businessServiceId String?
  employeeId        String?

  status BookingStatus @default(PENDING)

  agreedPriceCents Int?
  scheduledAt      DateTime?
  scheduledEndAt   DateTime? // For business bookings with duration
  completedAt      DateTime?

  // Client notes
  notes String?

  // P2P booking contact info (revealed only when accepted)
  requesterPhone   String?
  requesterAddress String?

  // Rejection message (when provider declines)
  rejectionMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  service         Service?         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  businessService BusinessService? @relation(fields: [businessServiceId], references: [id], onDelete: Cascade)
  employee        Employee?        @relation(fields: [employeeId], references: [id])
  requester       User             @relation("BookingRequester", fields: [requesterId], references: [id])
  provider        User             @relation("BookingProvider", fields: [providerId], references: [id])
  reviews         Review[]
  comments        BookingComment[]

  @@index([serviceId])
  @@index([businessServiceId])
  @@index([employeeId])
  @@index([requesterId])
  @@index([providerId])
  @@index([status])
  @@index([scheduledAt])
}

// ============================================
// BOOKING COMMENTS
// ============================================

model BookingComment {
  id        String   @id @default(cuid())
  bookingId String
  authorId  String
  content   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([authorId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String

  // Reference to related entity
  bookingId String?
  serviceId String?

  isRead    Boolean          @default(false)

  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================
// REVIEW
// ============================================

model Review {
  id           String     @id @default(cuid())
  bookingId    String
  authorId     String
  targetUserId String
  type         ReviewType
  score        Int        // 1-5
  comment      String?
  reply        String?    // Business owner reply
  repliedAt    DateTime?

  createdAt DateTime @default(now())

  // Relations
  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author     User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetUser User    @relation("ReviewTarget", fields: [targetUserId], references: [id])

  @@unique([bookingId, type])
  @@index([targetUserId])
}

// ============================================
// REPUTATION
// ============================================

model UserReputation {
  userId     String @id

  // ELO-style trust score (starts at 1000, goes up/down)
  elo         Int    @default(1000)

  // Rating stats
  ratingAvg5  Float  @default(0)
  ratingCount Int    @default(0)

  // Activity stats
  completedBookings Int @default(0)

  // Penalty tracking
  lateCancellationCount Int @default(0)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// ENUMS
// ============================================

enum SubscriptionStatus {
  FREE
  PRO
  CANCELED
}

enum ServiceKind {
  OFFER
  REQUEST
}

enum ServiceStatus {
  DRAFT
  PUBLISHED
  PAUSED
}

enum Urgency {
  URGENT
  SOON
  FLEXIBLE
}

enum Recurrence {
  ONE_TIME
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELED
}

enum ReviewType {
  REVIEW_PROVIDER
  REVIEW_REQUESTER
}

enum BusinessTier {
  STARTER   // Free tier - limited features
  PRO       // Monthly subscription - full features
  PREMIUM   // Premium features + priority support
}

enum NotificationType {
  BOOKING_NEW           // New booking received
  BOOKING_ACCEPTED      // Your booking was accepted
  BOOKING_REJECTED      // Your booking was rejected
  BOOKING_CANCELED      // Booking was canceled
  BOOKING_COMPLETED     // Booking was completed
  BOOKING_COMMENT       // New comment on booking
  REVIEW_RECEIVED       // Someone left you a review
}
