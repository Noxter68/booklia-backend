generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USER
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Better Auth fields
  name          String?
  emailVerified Boolean @default(false)
  image         String?

  // Admin flag
  isAdmin Boolean @default(false)

  // Preferred locale (fr, en, pt)
  locale String @default("fr")

  // Relations
  sessions            Session[]
  accounts            Account[]
  bookingsAsRequester Booking[]      @relation("BookingRequester")
  bookingsAsProvider  Booking[]      @relation("BookingProvider")
  reviewsWritten      Review[]       @relation("ReviewAuthor")
  reviewsReceived     Review[]       @relation("ReviewTarget")
  notifications       Notification[]

  // Business relations
  ownedBusiness Business?
  employeeAt    Employee?

  // Client management
  businessClients  BusinessClient[]
  bookingsCanceled Booking[]        @relation("BookingCanceler")

  // Booking notes
  bookingNotesAsClient BookingNote[] @relation("BookingNoteClient")
  bookingNotesCreated  BookingNote[] @relation("BookingNoteCreator")

  // Invoicing
  invoicesAsClient Invoice[] @relation("InvoiceClient")
  invoicesCreated  Invoice[] @relation("InvoiceCreator")

  // Batch generations
  batchGenerations BatchGeneration[] @relation("BatchGenerationCreator")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================
// BUSINESS
// ============================================

model Business {
  id           String  @id @default(cuid())
  ownerId      String  @unique
  name         String
  slug         String  @unique
  description  String?
  presentation String? // Rich HTML from WYSIWYG editor
  logoUrl      String?
  coverUrl     String?

  // Main Category (for search/filtering)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Contact
  phone   String?
  email   String?
  website String?

  // Address
  address    String?
  city       String?
  postalCode String?
  country    String  @default("FR")
  latitude   Float?
  longitude  Float?

  // Subscription
  subscriptionTier     BusinessTier       @default(STARTER)
  subscriptionStatus   SubscriptionStatus @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Settings
  isVerified           Boolean @default(false)
  isActive             Boolean @default(true)
  acceptsOnlineBooking Boolean @default(true)
  isEarlyAdopter       Boolean @default(false)

  // Vacation mode
  isOnVacation    Boolean @default(false)
  vacationMessage String?

  // Auto-accept bookings
  autoAcceptBookings Boolean @default(false)

  // Referral rewards: total free months earned via validated referrals
  // (each pair of validated referrals = 1 free month). Stripe credit is
  // applied manually for now.
  freeMonthsEarned Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner      User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  employees  Employee[]
  services   BusinessService[]
  hours      BusinessHours[]
  categories BusinessCategory[]
  images     BusinessImage[]
  promotions BusinessPromotion[]
  clients    BusinessClient[]

  // Booking notes & Invoicing
  bookingNotes     BookingNote[]
  billingSettings  BusinessBillingSettings?
  invoices         Invoice[]
  batchGenerations BatchGeneration[]

  // Referrals proposed by this business
  referrals Referral[]

  @@index([city])
  @@index([categoryId])
  @@index([latitude, longitude])
}

model BusinessPromotion {
  id          String   @id @default(cuid())
  businessId  String
  title       String
  description String?
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([startDate, endDate])
}

model BusinessImage {
  id         String @id @default(cuid())
  businessId String
  url        String
  sortOrder  Int    @default(0)

  createdAt DateTime @default(now())

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model BusinessClient {
  id         String  @id @default(cuid())
  businessId String
  userId     String
  isBlocked  Boolean @default(false)
  notes      String?
  phone      String?
  address    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
}

model Employee {
  id         String  @id @default(cuid())
  businessId String
  userId     String? @unique // Optional: can be linked to a user account

  firstName String
  lastName  String
  email     String?
  phone     String?
  avatarUrl String?
  role      String? // e.g. "Coiffeur", "Masseur", etc.
  bio       String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business       Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user           User?                  @relation(fields: [userId], references: [id])
  availabilities EmployeeAvailability[]
  services       EmployeeService[]
  bookings       Booking[]
  exceptions     EmployeeException[]

  @@index([businessId])
}

model EmployeeAvailability {
  id         String @id @default(cuid())
  employeeId String

  dayOfWeek Int // 0 = Sunday, 1 = Monday, etc.
  startTime String // "09:00"
  endTime   String // "18:00"

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Multiple slots per weekday allowed (e.g. 8-12 and 13-17)
  @@index([employeeId, dayOfWeek])
}

// Overrides the weekly availability for a specific day.
// isClosed=true means the employee is off and slots are ignored.
// Otherwise, the child EmployeeExceptionSlot rows define the effective
// time ranges for that date (can be zero, one, or many).
model EmployeeException {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime @db.Date // Pure date (no time) to avoid timezone drift
  isClosed   Boolean  @default(false)
  reason     String? // Internal note (e.g. "Vacances", "Formation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  employee Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  slots    EmployeeExceptionSlot[]

  @@unique([employeeId, date])
  @@index([employeeId, date])
}

// Individual time ranges attached to an exception (e.g. 08:00-12:00 + 13:00-18:00).
model EmployeeExceptionSlot {
  id          String @id @default(cuid())
  exceptionId String
  startTime   String // "09:00"
  endTime     String // "18:00"

  exception EmployeeException @relation(fields: [exceptionId], references: [id], onDelete: Cascade)

  @@index([exceptionId])
}

model BusinessHours {
  id         String @id @default(cuid())
  businessId String

  dayOfWeek Int // 0 = Sunday, 1 = Monday, etc.
  startTime String // "09:00"
  endTime   String // "18:00"
  isClosed  Boolean @default(false)

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

model BusinessCategory {
  id         String @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services BusinessService[]
  options  ServiceOption[]

  @@unique([businessId, name])
  @@index([businessId])
}

// Options attached to a BusinessCategory. Services created in that category
// can opt-in to any of these options. Options with the same non-null groupName
// form a radio group (single choice); options without groupName are free checkboxes.
model ServiceOption {
  id                 String  @id @default(cuid())
  businessCategoryId String
  name               String
  description        String? // optional short description shown to clients
  priceCents         Int     @default(0) // delta added on top of service price
  durationMinutes    Int? // optional extra duration (not used for now)
  groupName          String? // options sharing the same group are mutually exclusive
  sortOrder          Int     @default(0)
  isActive           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  businessCategory BusinessCategory @relation(fields: [businessCategoryId], references: [id], onDelete: Cascade)
  bookingOptions   BookingOption[]

  @@index([businessCategoryId])
}

model BusinessService {
  id         String @id @default(cuid())
  businessId String

  name                String
  description         String?
  detailedDescription String? // Rich text HTML content for detailed service info

  // Pricing
  priceMode  ServicePriceMode @default(FIXED)
  priceCents Int // ignored when priceMode != FIXED, but kept for history
  currency   String           @default("EUR")

  // Duration in minutes
  durationMinutes Int

  // Global Category (deprecated for business services)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Business-specific Category
  businessCategoryId String?
  businessCategory   BusinessCategory? @relation(fields: [businessCategoryId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business     Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employees    EmployeeService[]
  bookings     Booking[]
  pricingTiers ServicePricingTier[]

  @@index([businessId])
  @@index([categoryId])
  @@index([businessCategoryId])
}

// Loyalty pricing tiers: progressive surcharge applied when a client returns
// for the same service after a configured number of weeks since their last
// COMPLETED booking. Multiple tiers can stack — the highest matching tier wins.
model ServicePricingTier {
  id                String          @id @default(cuid())
  businessServiceId String
  businessService   BusinessService @relation(fields: [businessServiceId], references: [id], onDelete: Cascade)

  thresholdWeeks Int // surcharge applies when weeksSinceLast >= thresholdWeeks
  surchargeCents Int // amount added on top of the service base price

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessServiceId, thresholdWeeks])
  @@index([businessServiceId])
}

model EmployeeService {
  employeeId        String
  businessServiceId String

  // Relations
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  businessService BusinessService @relation(fields: [businessServiceId], references: [id], onDelete: Cascade)

  @@id([employeeId, businessServiceId])
}

// ============================================
// CATEGORY
// ============================================

model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  parentId String?

  // Translations stored as JSON: { "en": "Hairdresser", "pt": "Cabeleireiro" }
  // The "name" field is the default (French) name
  translations Json?

  parent           Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children         Category[]        @relation("CategoryHierarchy")
  businessServices BusinessService[]
  businesses       Business[]
}

// ============================================
// BOOKING
// ============================================

model Booking {
  id String @id @default(cuid())

  // Users involved
  requesterId String
  providerId  String

  // Business booking
  businessServiceId String?
  employeeId        String

  status BookingStatus @default(PENDING)

  // Calendar fields
  kind        CalendarEntryKind @default(APPOINTMENT)
  blockReason BlockReason?

  agreedPriceCents Int?
  scheduledAt      DateTime?
  scheduledEndAt   DateTime? // For business bookings with duration
  completedAt      DateTime?

  // Loyalty pricing trace: which tier (in weeks) was applied at booking time.
  // Null = first booking for this service or no tier matched.
  appliedTierWeeks Int?

  // Client notes
  notes String?

  // Rejection message (when provider declines)
  rejectionMessage String?

  // Who canceled (null if not canceled)
  canceledById String?

  // Email reminder tracking
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  businessService BusinessService? @relation(fields: [businessServiceId], references: [id], onDelete: Cascade)
  employee        Employee         @relation(fields: [employeeId], references: [id])
  requester       User             @relation("BookingRequester", fields: [requesterId], references: [id])
  provider        User             @relation("BookingProvider", fields: [providerId], references: [id])
  canceledBy      User?            @relation("BookingCanceler", fields: [canceledById], references: [id])
  reviews         Review[]
  bookingNote     BookingNote?
  invoice         Invoice?
  options         BookingOption[]

  @@index([businessServiceId])
  @@index([employeeId])
  @@index([requesterId])
  @@index([providerId])
  @@index([status])
  @@index([scheduledAt])
  @@index([employeeId, scheduledAt])
  @@index([requesterId, providerId])
  @@index([status, scheduledAt])
  // Loyalty lookup: "last COMPLETED booking of this user for this service".
  @@index([requesterId, businessServiceId, status, scheduledAt])
}

// Snapshot of options selected at booking time. Keeps name + price frozen
// so edits/deletes to ServiceOption don't retroactively change past bookings.
model BookingOption {
  id              String  @id @default(cuid())
  bookingId       String
  serviceOptionId String? // nullable so option deletion doesn't cascade-delete history
  name            String
  priceCents      Int

  createdAt DateTime @default(now())

  booking       Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceOption ServiceOption? @relation(fields: [serviceOptionId], references: [id], onDelete: SetNull)

  @@index([bookingId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  message String

  // Reference to related entity
  bookingId String?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead])
}

// ============================================
// REVIEW
// ============================================

model Review {
  id           String     @id @default(cuid())
  bookingId    String
  authorId     String
  targetUserId String
  type         ReviewType
  score        Int // 1-5
  comment      String?
  reply        String? // Business owner reply
  repliedAt    DateTime?

  createdAt DateTime @default(now())

  // Relations
  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author     User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetUser User    @relation("ReviewTarget", fields: [targetUserId], references: [id])

  @@unique([bookingId, type])
  @@index([targetUserId])
}

// ============================================
// ENUMS
// ============================================

enum SubscriptionStatus {
  FREE
  PRO
  CANCELED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum CalendarEntryKind {
  APPOINTMENT
  BLOCK
}

enum BlockReason {
  BREAK
  UNAVAILABLE
  PERSONAL
  CLOSED
}

enum ReviewType {
  REVIEW_PROVIDER
}

enum BusinessTier {
  STARTER // Free tier - limited features
  PRO // Monthly subscription - full features
  PREMIUM // Premium features + priority support
}

enum NotificationType {
  BOOKING_NEW // New booking received
  BOOKING_ACCEPTED // Your booking was accepted
  BOOKING_REJECTED // Your booking was rejected
  BOOKING_CANCELED // Booking was canceled
  BOOKING_COMPLETED // Booking was completed
  REVIEW_RECEIVED // Someone left you a review
}

enum NoteVisibility {
  PRIVATE_BUSINESS
}

enum VatMode {
  FRANCHISE_293B
  STANDARD
}

// FIXED  — flat priceCents charged at booking time (default behavior).
// QUOTE  — "Sur devis": no upfront price, the pro fixes the amount later.
// FREE   — Free / discovery appointment: no charge.
enum ServicePriceMode {
  FIXED
  QUOTE
  FREE
}

enum InvoiceStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum InvoiceLineKind {
  SERVICE
  PRODUCT
  OTHER
}

// ============================================
// BOOKING NOTES
// ============================================

model BookingNote {
  id              String         @id @default(cuid())
  businessId      String
  clientId        String // userId du client (requester)
  bookingId       String         @unique
  createdByUserId String
  visibility      NoteVisibility @default(PRIVATE_BUSINESS)
  content         String
  structured      Json?
  tags            String[]       @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client    User     @relation("BookingNoteClient", fields: [clientId], references: [id])
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdBy User     @relation("BookingNoteCreator", fields: [createdByUserId], references: [id])

  @@index([businessId, clientId, createdAt])
}

// ============================================
// BILLING & INVOICING
// ============================================

model BusinessBillingSettings {
  id                  String  @id @default(cuid())
  businessId          String  @unique
  legalName           String
  addressLine1        String
  addressLine2        String?
  postalCode          String
  city                String
  country             String  @default("FR")
  siret               String
  vatNumber           String?
  vatMode             VatMode @default(FRANCHISE_293B)
  invoicePrefix       String
  nextInvoiceSequence Int     @default(1)
  logoKey             String?
  paymentTerms        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String        @id @default(cuid())
  businessId      String
  clientId        String?
  bookingId       String?       @unique
  status          InvoiceStatus @default(DRAFT)
  invoiceNumber   String?
  issueDate       DateTime?
  serviceDate     DateTime?
  currency        String        @default("EUR")
  totalHTCents    Int           @default(0)
  totalVATCents   Int           @default(0)
  totalTTCCents   Int           @default(0)
  vatMode         VatMode       @default(FRANCHISE_293B)
  snapshot        Json?
  pdfKey          String?
  emailSentAt     DateTime?
  createdByUserId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business  Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client    User?         @relation("InvoiceClient", fields: [clientId], references: [id])
  booking   Booking?      @relation(fields: [bookingId], references: [id])
  createdBy User          @relation("InvoiceCreator", fields: [createdByUserId], references: [id])
  lines     InvoiceLine[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId, createdAt])
  @@index([businessId, status])
}

model InvoiceLine {
  id               String          @id @default(cuid())
  invoiceId        String
  kind             InvoiceLineKind @default(SERVICE)
  label            String
  quantity         Int             @default(1)
  unitPriceHTCents Int
  vatRate          Float           @default(0)
  totalHTCents     Int             @default(0)
  totalVATCents    Int             @default(0)
  totalTTCCents    Int             @default(0)
  sortOrder        Int             @default(0)

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============================================================================
// Batch Invoice Generation History
// ============================================================================

enum BatchGenerationStatus {
  COMPLETED
  FAILED
}

model BatchGeneration {
  id              String                @id @default(cuid())
  businessId      String
  createdByUserId String
  status          BatchGenerationStatus @default(COMPLETED)
  startDate       DateTime
  endDate         DateTime
  invoiceCount    Int                   @default(0)
  totalHTCents    Int                   @default(0)
  totalVATCents   Int                   @default(0)
  totalTTCCents   Int                   @default(0)
  invoiceIds      String[]
  errors          String[]
  createdAt       DateTime              @default(now())

  // Relations
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User     @relation("BatchGenerationCreator", fields: [createdByUserId], references: [id])

  @@index([businessId, createdAt])
}

// ============================================
// REFERRALS
// ============================================

enum ReferralStatus {
  PENDING
  VALIDATED
  REJECTED
}

model Referral {
  id              String         @id @default(cuid())
  businessId      String
  firstName       String
  lastName        String
  instagram       String // stored without leading "@"
  phone           String
  status          ReferralStatus @default(PENDING)
  notes           String? // admin-only notes
  rewardGrantedAt DateTime?
  validatedAt     DateTime?
  rejectedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([status, createdAt])
}

// ============================================
// INVITE REQUESTS (closed-beta lead capture)
// ============================================

model InviteRequest {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String
  notes     String? // admin-only notes
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}
