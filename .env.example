# ============================================
# DATABASE (Neon PostgreSQL)
# ============================================
# Use different Neon projects/branches for staging vs production
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ============================================
# APP
# ============================================
PORT=3001
NODE_ENV=development
# staging: https://staging.booklia.fr
# production: https://booklia.fr
FRONTEND_URL=http://localhost:3000

# ============================================
# AUTH (JWT)
# ============================================
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# ============================================
# STRIPE
# ============================================
# staging: use sk_test_... keys
# production: use sk_live_... keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BOOST_PRICE_ID=price_...

# ============================================
# CLOUDFLARE R2 STORAGE
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ============================================
# REDIS CACHE (Upstash)
# ============================================
# Use different Upstash databases for staging vs production
# Format: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Booklia <noreply@booklia.fr>
